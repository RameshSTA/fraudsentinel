# ─── Python ──────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
dist/
*.egg-info/
.eggs/
*.egg

# ─── Virtual Environments ────────────────────────────────────────────────────
.venv/
venv/
ENV/
env/

# ─── Data (large files — tracked by DVC, not Git) ────────────────────────────
data/raw/*.csv
data/raw/*.parquet
data/interim/*.parquet
data/processed/*.parquet
data/outputs/*.parquet
data/new/*.parquet

# ─── Model Artefacts (tracked by DVC) ────────────────────────────────────────
models/*.pt
models/*.joblib
# Keep .json files (small, human-readable config)
!models/*.json
!models/*.md

# ─── Secrets ──────────────────────────────────────────────────────────────────
.env
.env.*
*.pem
*.key
credentials.json
secrets.json
.secrets.baseline

# ─── IDE / OS ─────────────────────────────────────────────────────────────────
.DS_Store
.idea/
.vscode/
*.swp
*.swo
Thumbs.db

# ─── Testing & Coverage ──────────────────────────────────────────────────────
.coverage
htmlcov/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# ─── MLflow ──────────────────────────────────────────────────────────────────
mlruns/
mlartifacts/

# ─── Jupyter ─────────────────────────────────────────────────────────────────
.ipynb_checkpoints/
notebooks/.ipynb_checkpoints/

# ─── Reports (regenerated by pipeline) ───────────────────────────────────────
# Keep PNG and JSON report files in Git for reviewability
# Uncomment below if reports become too large:
# reports/*.png
# reports/*.json
# reports/*.html

# ─── DVC ─────────────────────────────────────────────────────────────────────
# DVC internal files ARE tracked in Git (they're small metadata)
# .dvc/cache is not
.dvc/cache/
.dvc/tmp/
